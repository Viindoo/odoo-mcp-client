<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="my_module.GreetingWidget">
        <div class="o_greeting" t-att-class="{ 'o_mobile': ui.isSmall }">
            <!-- auto-bound handler (safe) and explicit-this arrow (safe) -->
            <button class="btn btn-primary" t-on-click="onIncrement">Increment</button>
            <button class="btn btn-secondary" t-on-click="() => this.onIncrement()">Again</button>
            <!-- class-1 precision: params-before-arrow WITH this. prefix is still safe -->
            <button class="btn btn-link" t-on-click="(ev) => this.onIncrement(ev)">Bump</button>
            <span class="o_count" t-esc="state.count"/>
        </div>
    </t>
</templates>
