{
  "description": "odoo-semantic-skills hooks — SessionStart readiness probe + UserPromptSubmit intent detector + SubagentStop grounding enforcement.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-setup-deps.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/detect-intent.sh\"",
            "timeout": 8
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforce-grounding.sh\"",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
