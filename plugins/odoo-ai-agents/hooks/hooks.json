{
  "description": "odoo-ai-agents hooks — SessionStart readiness probe + browser-MCP permission self-apply + UserPromptSubmit intent detector + SubagentStop grounding enforcement & continuation nudge + PreToolUse delegate reminder + Stop continuation nudge (the drive-to-done hooks are ADVISORY: they never hard-block the main agent).",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/remind-delegate.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/drive-continuation.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/check-setup-deps.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/ensure-browser-permissions.sh\"",
            "timeout": 8
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "mcp__plugin_odoo-ai-agents_.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/auto-approve-browser.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/detect-intent.sh\"",
            "timeout": 8
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/enforce-grounding.sh\"",
            "timeout": 8
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/parse-continuation.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
