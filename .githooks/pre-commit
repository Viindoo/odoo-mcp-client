#!/usr/bin/env bash
# Confidentiality pre-commit hook for odoo-mcp-client.
# Blocks 8 categories of Viindoo-internal data leaks per plan §Confidentiality brief.
# Hard-fail (cannot bypass): vault paths, /home/tuan/. paths, personal email.
# Soft-warning (informational): specific numeric figures in markdown that look like pricing/OKR.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Get staged files (added or modified) under tracking
STAGED=$(git diff --cached --name-only --diff-filter=AM)
[ -z "$STAGED" ] && exit 0

# Filter to .md/.json/.py/.yaml/.yml
SCAN_FILES=""
for f in $STAGED; do
    case "$f" in
        *.md|*.json|*.py|*.yaml|*.yml)
            [ -f "$f" ] && SCAN_FILES="$SCAN_FILES $f"
            ;;
    esac
done

[ -z "$SCAN_FILES" ] && exit 0

# === HARD FAIL: vault and personal paths (8-category ban list) ===

# Pattern 1: vault path
if grep -lE '/home/tuan/git/obsidian-vault' $SCAN_FILES > /dev/null 2>&1; then
    echo "ERROR: vault path /home/tuan/git/obsidian-vault leaked in:" >&2
    grep -lE '/home/tuan/git/obsidian-vault' $SCAN_FILES >&2
    exit 1
fi

# Pattern 2: /home/tuan/. (dotfile / personal paths). Allow /home/tuan/git/<...> only when it's the OWN repo
# Banned: /home/tuan/.claude, /home/tuan/.config, /home/tuan/Desktop, /home/tuan/Downloads, etc.
if grep -lE '/home/tuan/\.' $SCAN_FILES > /dev/null 2>&1; then
    # Allow within the confidentiality CI regex block (which is documenting the ban list itself)
    OFFENDERS=$(grep -lE '/home/tuan/\.' $SCAN_FILES | grep -v 'docs/refinement-plan-2026-05-28.md')
    if [ -n "$OFFENDERS" ]; then
        echo "ERROR: personal path /home/tuan/. leaked in:" >&2
        echo "$OFFENDERS" >&2
        exit 1
    fi
fi

# Pattern 3: personal email
if grep -lE 'davidtran\.hp@gmail\.com' $SCAN_FILES > /dev/null 2>&1; then
    echo "ERROR: personal email leaked in:" >&2
    grep -lE 'davidtran\.hp@gmail\.com' $SCAN_FILES >&2
    exit 1
fi

# === SOFT WARNING: specific numbers that look like pricing/OKR (informational only) ===

if grep -lE '(\$[0-9]{4,}|[0-9]{1,3}([,.][0-9]{3}){2,}\s*(VND|USD)|OKR.*[0-9]{2}%)' $SCAN_FILES > /dev/null 2>&1; then
    echo "WARNING: possible sensitive number in markdown — review before pushing:" >&2
    grep -lE '(\$[0-9]{4,}|[0-9]{1,3}([,.][0-9]{3}){2,}\s*(VND|USD)|OKR.*[0-9]{2}%)' $SCAN_FILES >&2
    # Allow override via commit message tag
    if git diff --cached --stat | grep -q '\[allow-confidentiality-warning\]'; then
        echo "(bypassed via [allow-confidentiality-warning] in commit message)" >&2
    fi
fi

exit 0
