#!/usr/bin/env bash
# Confidentiality pre-commit hook for odoo-mcp-client.
# All content checks use `git show :"$f"` to read the STAGED blob,
# not the working-tree file. Closes the stage-then-clean bypass vector.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

SCAN_FILES=()
while IFS= read -r -d '' f; do
    case "$f" in
        *.md|*.json|*.py|*.yaml|*.yml|*.sh)
            SCAN_FILES+=("$f")
            ;;
    esac
done < <(git diff --cached --name-only -z --diff-filter=AM)

[ ${#SCAN_FILES[@]} -eq 0 ] && exit 0

staged_content() {
    git show :"$1" 2>/dev/null
}

HARD_FAIL=0

for f in "${SCAN_FILES[@]}"; do
    # Pattern 1: vault path
    if staged_content "$f" | grep -qE '/home/tuan/git/obsidian-vault'; then
        echo "ERROR: vault path leaked in staged blob: $f" >&2
        HARD_FAIL=1
    fi

    # Pattern 2: personal /home/tuan/.
    if staged_content "$f" | grep -qE '/home/tuan/\.'; then
        echo "ERROR: personal path /home/tuan/. leaked in staged blob: $f" >&2
        HARD_FAIL=1
    fi

    # Pattern 3: personal email
    if staged_content "$f" | grep -qE 'davidtran\.hp@gmail\.com'; then
        echo "ERROR: personal email leaked in staged blob: $f" >&2
        HARD_FAIL=1
    fi

    # Pattern 4: Vietnam regulation (BVDLCN)
    if staged_content "$f" | grep -qiE 'BVDLCN'; then
        echo "ERROR: Vietnam regulation reference (BVDLCN) found in staged blob: $f" >&2
        HARD_FAIL=1
    fi

    # Pattern 5: Vietnam competitor (MISA)
    if staged_content "$f" | grep -qiE '\bMISA\b'; then
        echo "ERROR: Vietnam competitor reference (MISA) found in staged blob: $f" >&2
        HARD_FAIL=1
    fi

    # Pattern 6: Vietnam competitors (1Office, Portcities)
    if staged_content "$f" | grep -qiE '(1Office|Portcities)'; then
        echo "ERROR: Vietnam competitor reference (1Office/Portcities) found in staged blob: $f" >&2
        HARD_FAIL=1
    fi

    # Pattern 7: Vietnam SME framing
    if staged_content "$f" | grep -qE 'một-người-công-ty'; then
        echo "ERROR: Vietnam SME framing reference found in staged blob: $f" >&2
        HARD_FAIL=1
    fi
done

[ "$HARD_FAIL" -eq 1 ] && exit 1

for f in "${SCAN_FILES[@]}"; do
    if staged_content "$f" | grep -qE '(\$[0-9]{4,}|[0-9]{1,3}([,.][0-9]{3}){2,}\s*(VND|USD)|OKR.*[0-9]{2}%)'; then
        echo "WARNING: possible sensitive number in staged blob — review before pushing: $f" >&2
    fi
done

exit 0
